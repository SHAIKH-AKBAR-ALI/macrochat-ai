---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Sign up — MacroChat AI">
  <div class="wrap" style="max-width:560px; padding:4rem 0;">
    <p class="eyebrow" data-rise="1">Goals computed from your body — not vibes</p>
    <h1 style="font-size:clamp(2.2rem,6vw,3.5rem); margin:1rem 0 2rem;" data-rise="2">Sign up</h1>
    <form id="signup-form" class="block auth-card" data-rise="3">
      <p class="form-error" id="err" role="alert"></p>

      <label class="field"><span>Email</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label class="field"><span>Password</span>
        <input type="password" name="password" required minlength="6" autocomplete="new-password" />
      </label>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0 1rem;">
        <label class="field"><span>Height (cm)</span>
          <input type="number" name="height_cm" required min="100" max="250" step="0.1" />
        </label>
        <label class="field"><span>Weight (kg)</span>
          <input type="number" name="weight_kg" required min="30" max="300" step="0.1" />
        </label>
        <label class="field"><span>Age</span>
          <input type="number" name="age" required min="13" max="120" />
        </label>
        <label class="field"><span>Sex</span>
          <select name="sex" required>
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </label>
      </div>

      <label class="field"><span>Activity level</span>
        <select name="activity_level" required>
          <option value="sedentary">Sedentary — desk day, little exercise</option>
          <option value="light">Light — exercise 1–3 days/week</option>
          <option value="moderate" selected>Moderate — exercise 3–5 days/week</option>
          <option value="active">Active — exercise 6–7 days/week</option>
          <option value="very_active">Very active — hard training daily</option>
        </select>
      </label>

      <label class="field"><span>Goal</span>
        <select name="goal" required>
          <option value="lose">Lose weight</option>
          <option value="maintain" selected>Maintain</option>
          <option value="gain">Gain muscle</option>
        </select>
      </label>

      <label class="field"><span>Time zone (auto-detected — fix if wrong)</span>
        <input type="text" name="time_zone" id="tz" required />
      </label>

      <button class="btn" type="submit" id="submit" style="width:100%;">Create account</button>
    </form>
    <p class="mono" style="margin-top:1rem;">Have an account? <a href="/login">Log in</a></p>
  </div>

  <script>
    import { jsonPost } from "../lib/api";

    (document.getElementById("tz") as HTMLInputElement).value =
      Intl.DateTimeFormat().resolvedOptions().timeZone;

    const form = document.getElementById("signup-form") as HTMLFormElement;
    const err = document.getElementById("err")!;
    const submit = document.getElementById("submit") as HTMLButtonElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      err.classList.remove("show");
      submit.disabled = true;
      const fd = new FormData(form);
      const body = {
        email: fd.get("email"),
        password: fd.get("password"),
        height_cm: Number(fd.get("height_cm")),
        weight_kg: Number(fd.get("weight_kg")),
        age: Number(fd.get("age")),
        sex: fd.get("sex"),
        activity_level: fd.get("activity_level"),
        goal: fd.get("goal"),
        time_zone: fd.get("time_zone"),
      };
      try {
        await jsonPost("/signup", body);
        const login = await jsonPost("/login", {
          email: body.email,
          password: body.password,
        });
        localStorage.setItem("mc_token", login.access_token);
        location.href = "/dashboard";
      } catch (ex: any) {
        err.textContent = ex.message;
        err.classList.add("show");
        submit.disabled = false;
      }
    });
  </script>
</Layout>
