---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Contact — MacroChat AI">
  <section class="band">
    <div class="wrap" style="max-width:760px;">
      <p class="eyebrow">Contact us</p>
      <h1 style="font-size:clamp(2.2rem,6vw,4rem); margin:1.2rem 0 1.5rem;">Say hello.</h1>

      <div class="block" style="margin-bottom:1.5rem;">
        <h3 style="margin-bottom:0.6rem;">Email</h3>
        <p>Bug reports, feature ideas, data deletion requests, or anything else:</p>
        <p style="margin-top:0.8rem;">
          <a class="btn" href="mailto:mimali31394@gmail.com">mimali31394@gmail.com</a>
        </p>
      </div>

      <div class="block">
        <h3 style="margin-bottom:0.6rem;">Found a wrong number?</h3>
        <p>If a food matched the wrong database entry or a calorie count looks off,
        email a screenshot — matching accuracy is the thing we care most about
        fixing.</p>
      </div>
    </div>
  </section>
</Layout>
