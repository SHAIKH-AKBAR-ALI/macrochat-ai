---
import Layout from "../layouts/Layout.astro";
---
<Layout title="500 — MacroChat AI">
  <section class="hero">
    <div class="wrap" style="text-align:center; padding:3rem 0;">
      <p class="eyebrow" data-rise="1">Error 500</p>
      <h1 style="margin:1.5rem 0 1rem;" data-rise="2">Something<br /><span>broke.</span></h1>
      <p class="hero__lead" style="margin-inline:auto;" data-rise="3">
        Not you — us. Give it a moment and try again. Your logged meals are safe.
      </p>
      <div data-rise="4">
        <a class="btn" href="/">Back home</a>
      </div>
    </div>
  </section>
</Layout>
