---
import Layout from "../layouts/Layout.astro";
---
<Layout title="404 — MacroChat AI">
  <section class="hero">
    <div class="wrap" style="text-align:center; padding:3rem 0;">
      <p class="eyebrow" data-rise="1">Error 404</p>
      <h1 style="margin:1.5rem 0 1rem;" data-rise="2">Page not<br /><span>found.</span></h1>
      <p class="hero__lead" style="margin-inline:auto;" data-rise="3">
        This page isn't in our database — and unlike calories, we won't make one up.
      </p>
      <div data-rise="4">
        <a class="btn" href="/">Back home</a>
        <a class="btn btn--ghost" href="/chat" style="margin-left:0.6rem;">Log a meal</a>
      </div>
    </div>
  </section>
</Layout>
