---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Today — MacroChat AI" active="dashboard">
  <div class="wrap" style="max-width:820px; padding:3rem 0 4rem;">
    <p class="eyebrow" id="date-label">Today</p>
    <h1 style="font-size:clamp(2.2rem,6vw,4rem); margin:1rem 0 2rem;">Your day</h1>

    <div id="loading" class="mono">Loading today's totals…</div>

    <div id="board" style="display:none;">
      <div style="display:grid; grid-template-columns:1fr; gap:2rem;">
        <div class="block">
          <div id="meters"></div>
          <p class="mono" id="meals-count" style="margin-top:0.5rem;"></p>
        </div>

        <div class="facts">
          <div class="facts__title">Remaining today</div>
          <div class="facts__row facts__row--hero">
            <b>Calories left</b><span class="num" id="rem-kcal"></span>
          </div>
          <div class="facts__row"><b>Protein left</b><span class="num" id="rem-protein"></span></div>
          <div class="facts__row"><b>Carbs left</b><span class="num" id="rem-carbs"></span></div>
          <div class="facts__row"><b>Fat left</b><span class="num" id="rem-fat"></span></div>
          <div class="facts__note">Counted from your local midnight — backend math, not AI guesses</div>
        </div>

        <a class="btn" href="/chat" style="justify-self:start;">Log a meal</a>
      </div>
    </div>
  </div>

  <script>
    import { API, token, authHeaders } from "../lib/api";

    if (!token()) location.href = "/login";

    document.getElementById("date-label")!.textContent =
      new Date().toLocaleDateString(undefined, { weekday: "long", month: "long", day: "numeric" });

    const MACROS = [
      ["kcal", "Calories", "kcal"],
      ["protein", "Protein", "g"],
      ["carbs", "Carbs", "g"],
      ["fat", "Fat", "g"],
    ] as const;

    async function load() {
      const res = await fetch(API + "/today", { headers: authHeaders() });
      if (res.status === 401) { localStorage.removeItem("mc_token"); location.href = "/login"; return; }
      const t = await res.json();

      const meters = document.getElementById("meters")!;
      meters.innerHTML = ""; // load() can rerun (bfcache restore) — never stack meters
      for (const [key, label, unit] of MACROS) {
        const eaten = t.eaten[key], goal = t.goals[key];
        const pct = Math.min(100, Math.round((eaten / goal) * 100));
        const m = document.createElement("div");
        m.className = "meter";
        m.innerHTML = `
          <div class="meter__label">
            <span>${label}</span>
            <span>${eaten} / ${goal} ${unit}</span>
          </div>
          <div class="meter__track" role="meter" aria-label="${label}"
               aria-valuenow="${eaten}" aria-valuemin="0" aria-valuemax="${goal}">
            <div class="meter__fill${eaten > goal ? " over" : ""}" style="width: ${pct}%"></div>
          </div>`;
        meters.append(m);
      }

      for (const [key, , unit] of MACROS) {
        document.getElementById(`rem-${key === "kcal" ? "kcal" : key}`)!.textContent =
          `${t.remaining[key]} ${unit}`;
      }
      document.getElementById("meals-count")!.textContent =
        `${t.meals_logged} meal${t.meals_logged === 1 ? "" : "s"} logged today`;

      document.getElementById("loading")!.style.display = "none";
      document.getElementById("board")!.style.display = "block";
    }
    load();
    // Back-button restores the page from bfcache with STALE numbers — refetch.
    window.addEventListener("pageshow", (e) => {
      if ((e as PageTransitionEvent).persisted) load();
    });
  </script>
</Layout>
